{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/evolv3ai/admin-suite/profile-schema.json",
  "title": "Device Profile Schema v4.1",
  "description": "Unified device profile for context-aware development assistance. v4.1 adds bindings (per-component secretRefs/fileRefs/env).",
  "type": "object",
  "required": ["schemaVersion", "device", "packageManagers", "tools"],
  "$defs": {
    "componentBinding": {
      "type": "object",
      "description": "Per-component binding: secrets, files, env, and install state",
      "properties": {
        "secretRefs": {
          "type": "object",
          "description": "Maps secret names to infisical:// URIs",
          "additionalProperties": { "type": "string" }
        },
        "fileRefs": {
          "type": "object",
          "description": "Maps file names to URI + renderTo path",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "uri": { "type": "string" },
              "renderTo": { "type": "string" },
              "mode": { "type": "string", "default": "0600" }
            },
            "required": ["uri", "renderTo"]
          }
        },
        "env": {
          "type": "object",
          "description": "Static (non-secret) environment variables",
          "additionalProperties": { "type": "string" }
        },
        "status": {
          "enum": ["active", "disabled", "pending", "error"],
          "description": "active=working, disabled=intentionally off, pending=not yet rendered, error=resolution failed"
        },
        "installedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this binding was created"
        },
        "lastSyncedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time this binding was refreshed from library"
        },
        "installPolicy": {
          "enum": ["library", "plugin", "manual"],
          "description": "How this component was installed (library=Library managed, plugin=Claude Code plugin, manual=user)"
        }
      }
    }
  },
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["3.0", "4.0", "4.1"],
      "description": "Schema version (4.1 adds bindings, replaces flat secretRefs/fileRefs)"
    },
    "adminSkillVersion": {
      "type": "string",
      "description": "Version of admin skill that created/last updated this profile"
    },
    "multiDevice": {
      "type": "boolean",
      "description": "Whether this is a multi-device setup with cloud-synced storage"
    },
    "skillVersions": {
      "type": "object",
      "description": "Version tracking for all admin suite skills",
      "additionalProperties": { "type": "string" }
    },
    "device": {
      "type": "object",
      "description": "Core device identity and hardware",
      "required": ["name", "platform", "user"],
      "properties": {
        "name": { "type": "string", "description": "Hostname/device name" },
        "platform": { "enum": ["windows", "macos", "linux"], "description": "Primary OS" },
        "shell": { "enum": ["powershell", "pwsh", "bash", "zsh", "fish"], "description": "Default shell" },
        "user": { "type": "string", "description": "Primary username" },
        "os": { "type": "string", "description": "Full OS name (e.g., Windows 11 Pro)" },
        "osVersion": { "type": "string", "description": "OS build/version" },
        "architecture": { "enum": ["AMD64", "ARM64", "x86"], "description": "CPU architecture" },
        "cpu": { "type": "string", "description": "CPU model" },
        "cores": { "type": "integer", "description": "Physical cores" },
        "threads": { "type": "integer", "description": "Logical threads" },
        "ram": { "type": "string", "description": "Total RAM (e.g., 64 GB)" },
        "timezone": { "type": "string", "description": "System timezone" },
        "initialized": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "paths": {
      "type": "object",
      "description": "Critical filesystem locations",
      "properties": {
        "adminRoot": { "type": "string" },
        "deviceProfile": { "type": "string" },
        "logs": { "type": "string" },
        "claudeConfig": { "type": "string" },
        "claudeSkills": { "type": "string" },
        "mcpServers": { "type": "string" },
        "sshKeys": { "type": "string" },
        "projects": { "type": "string" },
        "dropbox": { "type": ["string", "null"] },
        "npmGlobal": { "type": "string" },
        "pythonVenvs": { "type": "string" }
      }
    },
    "packageManagers": {
      "type": "object",
      "description": "Available package managers",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "present": { "type": "boolean" },
          "version": { "type": ["string", "null"] },
          "path": { "type": ["string", "null"] },
          "location": { "type": ["string", "null"] },
          "lastChecked": { "type": "string", "format": "date-time" },
          "preferred": { "type": "boolean" }
        }
      }
    },
    "tools": {
      "type": "object",
      "description": "Installed development tools",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "present": { "type": "boolean" },
          "version": { "type": ["string", "null"] },
          "installedVia": { "type": ["string", "null"] },
          "path": { "type": ["string", "null"] },
          "shimPath": { "type": ["string", "null"] },
          "configPath": { "type": ["string", "null"] },
          "lastChecked": { "type": "string", "format": "date-time" },
          "installStatus": { "enum": ["working", "failed", "pending", "deprecated"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "preferences": {
      "type": "object",
      "description": "User preferences",
      "properties": {
        "python": { "type": "object", "properties": { "manager": { "enum": ["uv", "pip", "conda", "poetry", "pipenv"] }, "reason": { "type": "string" } } },
        "node": { "type": "object", "properties": { "manager": { "enum": ["npm", "pnpm", "yarn", "bun"] }, "reason": { "type": "string" } } },
        "packages": { "type": "object", "properties": { "manager": { "enum": ["scoop", "winget", "chocolatey", "brew", "apt"] }, "reason": { "type": "string" } } },
        "shell": { "type": "object", "properties": { "preferred": { "type": "string" }, "profilePath": { "type": "string" } } },
        "editor": { "type": "string" },
        "terminal": { "type": "string" }
      }
    },
    "wsl": { "type": ["object", "null"] },
    "docker": { "type": ["object", "null"] },
    "mcp": { "type": "object", "description": "MCP server configurations" },
    "servers": { "type": "array", "description": "Managed remote servers" },
    "issues": { "type": "object" },
    "history": { "type": "array" },
    "capabilities": { "type": "object" },
    "vault": {
      "type": ["object", "null"],
      "description": "Age-encrypted secrets vault configuration",
      "properties": {
        "enabled": { "type": "boolean" },
        "vaultPath": { "type": "string" },
        "keyPath": { "type": "string" },
        "publicKey": { "type": "string" },
        "migratedAt": { "type": "string", "format": "date-time" },
        "secretCount": { "type": "integer" }
      }
    },
    "secrets": {
      "type": ["object", "null"],
      "description": "Legacy secrets backend config (v3.0). Use secretsConfig for v4.0+",
      "properties": {
        "backend": { "enum": ["infisical", "vault", "env"] },
        "fallback": { "enum": ["vault", "env", "none"] },
        "infisical": { "type": ["object", "null"], "properties": { "projectId": { "type": "string" }, "environment": { "type": "string" }, "authMethod": { "enum": ["machine-identity", "cli-login"] } } }
      }
    },
    "secretRefs": {
      "type": "object",
      "description": "DEPRECATED (v4.0). Use bindings.*.secretRefs in v4.1+",
      "additionalProperties": { "type": "string" }
    },
    "fileRefs": {
      "type": "object",
      "description": "DEPRECATED (v4.0). Use bindings.*.fileRefs in v4.1+",
      "additionalProperties": { "type": "object" }
    },
    "bindings": {
      "type": "object",
      "description": "Per-component bindings (v4.1+). Each key maps component name to its secrets, files, env, and status.",
      "properties": {
        "mcp": { "type": "object", "additionalProperties": { "$ref": "#/$defs/componentBinding" } },
        "skill": { "type": "object", "additionalProperties": { "$ref": "#/$defs/componentBinding" } },
        "agent": { "type": "object", "additionalProperties": { "$ref": "#/$defs/componentBinding" } },
        "prompt": { "type": "object", "additionalProperties": { "$ref": "#/$defs/componentBinding" } }
      }
    },
    "secretsConfig": {
      "type": ["object", "null"],
      "description": "Multi-project secrets configuration (v4.0+)",
      "properties": {
        "backend": { "enum": ["infisical", "vault", "env"] },
        "fallback": { "enum": ["vault", "env", "none"] },
        "multiProject": { "type": "boolean" },
        "projectsConfig": { "type": "string" }
      }
    },
    "consumer": {
      "type": ["object", "null"],
      "description": "What type of consumer this profile represents",
      "properties": {
        "type": { "enum": ["workstation", "runtime", "customer-pc"] },
        "runtime": { "type": ["string", "null"], "description": "Runtime identifier (e.g., kasm-hetzner-02)" },
        "trustBoundary": { "enum": ["operator", "runtime", "customer"] }
      }
    },
    "access": {
      "type": ["object", "null"],
      "description": "Infisical access scope for this consumer",
      "properties": {
        "projects": { "type": "array", "items": { "type": "string" } },
        "folders": { "type": "array", "items": { "type": "string" } }
      }
    },
    "generated": {
      "type": ["object", "null"],
      "description": "Paths to generated runtime files",
      "properties": {
        "envFile": { "type": "string" },
        "compatFile": { "type": "string" },
        "agentsMd": { "type": "string" },
        "lastRendered": { "type": "string", "format": "date-time" }
      }
    },
    "deployments": {
      "type": "object",
      "description": "Deployment configurations",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "envFile": { "type": "string" },
          "type": { "enum": ["coolify", "kasm", "both", "custom"] },
          "provider": { "type": "string" },
          "status": { "enum": ["active", "stopped", "failed", "pending", "retired"] },
          "serverIds": { "type": "array", "items": { "type": "string" } },
          "lastDeployed": { "type": "string", "format": "date-time" },
          "notes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
